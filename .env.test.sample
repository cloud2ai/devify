# Relay integration test environment.
#
# Copy this file to `.env.test` and fill in real values.
# The `.env.test` file is ignored by git and only used locally for
# pytest-based integration runs.

# JIRA real environment
JIRA_URL=
JIRA_USERNAME=
JIRA_PASSWORD=
JIRA_PROJECT_KEY=REQ
JIRA_ISSUE_TYPE=Task
JIRA_PRIORITY=Medium
JIRA_SUMMARY_PREFIX=[DEVIFY TEST]

# Feishu / Lark real environment
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_WIKI_APP_TOKEN=
FEISHU_TABLE_NAME=
FEISHU_ATTACHMENT_FIELD_NAME=附件
FEISHU_APP_TOKEN_TYPE=bitable
FEISHU_SUMMARY_PREFIX=[DEVIFY TEST] 

# Optional overrides used by integration test payloads
RELAY_LLM_CONFIG_UUID=
RELAY_TEST_SUMMARY_TITLE=devify test summary
RELAY_TEST_SUMMARY_CONTENT=devify test description
RELAY_TEST_LLM_CONTENT=devify test description
